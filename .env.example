# --- Database ---
# docker-compose maps the PostGIS container to HOST PORT 5433 (5432 is often
# owned by a native PostgreSQL install that lacks PostGIS — connecting to it
# fails at grid creation). If your password contains special characters,
# URL-encode them in DATABASE_URL (e.g. @ -> %40).
POSTGRES_USER=urbanair
POSTGRES_PASSWORD=urbanair
POSTGRES_DB=urbanair
DATABASE_URL=postgresql+psycopg2://urbanair:urbanair@localhost:5433/urbanair

# --- Cache ---
REDIS_URL=redis://localhost:6379/0

# --- Backend ---
BACKEND_CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# --- Data source API keys (needed starting Step 2) ---
OPENAQ_API_KEY=
NASA_FIRMS_MAP_KEY=
COPERNICUS_CDSE_USERNAME=
COPERNICUS_CDSE_PASSWORD=

# --- LLM provider (needed starting Step 6) ---
LLM_PROVIDER=groq
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# --- Frontend (put in frontend/.env.local, mirrored here for reference) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=
